<mvc:View xmlns:mvc="sap.ui.core.mvc" xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:t="sap.ui.table"  xmlns:f="sap.ui.layout.form" controllerName="shiva.controller.view2">
      <Page title="{local>name}" showNavButton="true" navButtonPress="onBack">
             <ObjectHeader title="{local>name}" intro="{local>healthBenefit}" number="{local>price}" numberUnit="{local>currency}" icon="{local>imageURL}"></ObjectHeader>

             <IconTabBar>
                  <items>
                        <IconTabFilter text="Details" icon="sap-icon://warning">
                              <core:Fragment fragmentName="shiva.fragments.additionalData" type="XML"></core:Fragment>
                        </IconTabFilter>    


                        <IconTabFilter text="Suppliers" icon="sap-icon://supplier">
                              <core:Fragment fragmentName="shiva.fragments.supplier" type="XML"></core:Fragment>     
                        </IconTabFilter>  


                        <IconTabFilter text="Cities" icon="sap-icon://home"> 
                               <core:Fragment fragmentName="shiva.fragments.cities" type="XML"></core:Fragment>
                        </IconTabFilter>                        
                  </items>
             </IconTabBar>
             <footer>
                 <Toolbar >
                        <ToolbarSpacer ></ToolbarSpacer>
                          <Button text="Save" icon="sap-icon://save"  press="onSave"></Button>
                     
                 </Toolbar>
             </footer>
      </Page>
</mvc:View>